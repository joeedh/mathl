{
  "prettier.configPath"  : ".prettierrc",
  "prettier.prettierPath": "./node_modules/@pathtx/prettier/index.cjs",
  "search.exclude": {
    "**/build/**"            : true,
    "**/node_modules/**"     : true,
    "**/esdocs/**"           : true,
    "scripts/path.ux/docs/**": true,
    "scripts/path.ux/dist/**": true,
    "**/.git"                : true,
    "**/.pnpm-cache"         : true,
    "**/.pnpm-store"         : true,
    "**/.turbo"              : true,
    "**/bower_components"    : true,
    "**/*.code-search"       : true,
    "**/.dart_tool"          : true
  }
}
